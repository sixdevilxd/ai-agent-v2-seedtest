# Salin file ini menjadi .env lalu isi nilainya.
# JANGAN commit file .env asli ke GitHub!

# Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=

# API key Google Gemini dari https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# (Opsional) model Gemini yang dipakai
GEMINI_MODEL=gemini-1.5-flash

# (Opsional) kepribadian/instruksi sistem untuk agent.
# Dibiarkan kosong = pakai file system_prompt.md (skill "Fable 5").
# Isi baris ini kalau mau menimpa isi system_prompt.md.
# SYSTEM_PROMPT=Kamu adalah ai-agent-v2, asisten AI yang ramah dan cerdas.

# (Opsional) jumlah giliran percakapan yang diingat
MAX_HISTORY_TURNS=12
